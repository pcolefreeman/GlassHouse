"""Tests for HeartRateAnalyzer, PresenceScorer, and dual-band fusion."""
import numpy as np
import pytest


class TestHeartRateAnalyzer:
    def test_synthetic_heartbeat_detected(self):
        """1.0 Hz sinusoid (60 BPM) in HR band should yield high confidence."""
        from ghv4.breathing import HeartRateAnalyzer
        analyzer = HeartRateAnalyzer()
        n_time = 300  # 15s at 20 Hz
        n_pairs = 10
        t = np.arange(n_time) / 20.0
        phases = np.column_stack([np.sin(2 * np.pi * 1.0 * t)] * n_pairs).astype(np.float32)
        confidence, bpm = analyzer.analyze(phases)
        assert confidence > 0.3, f"Expected HR detection, got confidence={confidence}"
        assert 55 < bpm < 65, f"Expected ~60 BPM, got {bpm}"

    def test_breathing_freq_not_detected_as_hr(self):
        """0.25 Hz (breathing) should yield low HR confidence."""
        from ghv4.breathing import HeartRateAnalyzer
        analyzer = HeartRateAnalyzer()
        n_time = 300
        n_pairs = 10
        t = np.arange(n_time) / 20.0
        phases = np.column_stack([np.sin(2 * np.pi * 0.25 * t)] * n_pairs).astype(np.float32)
        confidence, bpm = analyzer.analyze(phases)
        assert confidence < 0.2, f"Breathing freq should not trigger HR: confidence={confidence}"

    def test_static_signal_no_hr(self):
        """Constant phase should yield zero HR confidence."""
        from ghv4.breathing import HeartRateAnalyzer
        analyzer = HeartRateAnalyzer()
        phases = np.zeros((300, 10), dtype=np.float32)
        confidence, bpm = analyzer.analyze(phases)
        assert confidence < 0.1
        assert bpm == 0.0

    def test_returns_tuple(self):
        """analyze() must return (confidence, bpm) tuple."""
        from ghv4.breathing import HeartRateAnalyzer
        analyzer = HeartRateAnalyzer()
        phases = np.zeros((300, 10), dtype=np.float32)
        result = analyzer.analyze(phases)
        assert isinstance(result, tuple)
        assert len(result) == 2

    def test_72_bpm_extraction(self):
        """1.2 Hz sinusoid (72 BPM) should be correctly estimated."""
        from ghv4.breathing import HeartRateAnalyzer
        analyzer = HeartRateAnalyzer()
        n_time = 300
        n_pairs = 10
        t = np.arange(n_time) / 20.0
        phases = np.column_stack([np.sin(2 * np.pi * 1.2 * t)] * n_pairs).astype(np.float32)
        confidence, bpm = analyzer.analyze(phases)
        assert confidence > 0.3
        assert 68 < bpm < 76, f"Expected ~72 BPM, got {bpm}"


class TestPresenceScorer:
    def test_one_attenuated_path_detected(self):
        """One path with higher amplitude should score higher than others."""
        from ghv4.breathing import PresenceScorer, CSIRingBuffer
        from ghv4.config import BREATHING_WINDOW_N, BREATHING_PATH_MAP
        scorer = PresenceScorer()
        buffers = {}
        rng = np.random.default_rng(42)
        hot_path = (1, 3)
        for key in BREATHING_PATH_MAP:
            buf = CSIRingBuffer(capacity=BREATHING_WINDOW_N)
            for _ in range(BREATHING_WINDOW_N):
                if key == hot_path:
                    csi = (rng.standard_normal(128) * 5.0 + 10.0).astype(np.complex64)
                else:
                    csi = (rng.standard_normal(128) * 0.1 + 1.0).astype(np.complex64)
                buf.push(csi)
            buffers[key] = buf
        scores = scorer.score(buffers)
        assert scores[hot_path] > scores[(2, 3)], \
            f"Hot path {scores[hot_path]} should exceed cold {scores[(2, 3)]}"

    def test_all_equal_paths_low_scores(self):
        """All paths with identical signal should yield similar low scores."""
        from ghv4.breathing import PresenceScorer, CSIRingBuffer
        from ghv4.config import BREATHING_WINDOW_N, BREATHING_PATH_MAP
        scorer = PresenceScorer()
        buffers = {}
        for key in BREATHING_PATH_MAP:
            buf = CSIRingBuffer(capacity=BREATHING_WINDOW_N)
            for _ in range(BREATHING_WINDOW_N):
                csi = np.ones(128, dtype=np.complex64) * 5.0
                buf.push(csi)
            buffers[key] = buf
        scores = scorer.score(buffers)
        values = list(scores.values())
        assert max(values) - min(values) < 0.3, f"Spread too high: {values}"

    def test_returns_dict_with_path_keys(self):
        """Score dict keys must match buffer keys."""
        from ghv4.breathing import PresenceScorer, CSIRingBuffer
        from ghv4.config import BREATHING_WINDOW_N, BREATHING_PATH_MAP
        scorer = PresenceScorer()
        buffers = {}
        for key in BREATHING_PATH_MAP:
            buf = CSIRingBuffer(capacity=BREATHING_WINDOW_N)
            for _ in range(BREATHING_WINDOW_N):
                buf.push(np.ones(128, dtype=np.complex64))
            buffers[key] = buf
        scores = scorer.score(buffers)
        assert set(scores.keys()) == set(BREATHING_PATH_MAP.keys())
        for v in scores.values():
            assert 0.0 <= v <= 1.0


class TestHeartRateAnalyzerEdgeCases:
    """Additional edge-case tests for HeartRateAnalyzer."""

    def test_noise_confidence_bounded(self):
        """White noise HR confidence should be bounded (not saturate at 1.0)."""
        from ghv4.breathing import HeartRateAnalyzer
        analyzer = HeartRateAnalyzer()
        rng = np.random.default_rng(77)
        phases = rng.standard_normal((300, 10)).astype(np.float32)
        confidence, bpm = analyzer.analyze(phases)
        # Noise has spectral energy in HR band; confidence should stay below 1.0
        assert confidence < 1.0, f"Noise confidence should not saturate: {confidence}"
        assert isinstance(confidence, float)
        assert isinstance(bpm, float)

    def test_100_bpm_extraction(self):
        """1.667 Hz sinusoid (~100 BPM) should be correctly estimated."""
        from ghv4.breathing import HeartRateAnalyzer
        analyzer = HeartRateAnalyzer()
        n_time = 300
        n_pairs = 10
        t = np.arange(n_time) / 20.0
        freq = 100.0 / 60.0  # ~1.667 Hz
        phases = np.column_stack([np.sin(2 * np.pi * freq * t)] * n_pairs).astype(np.float32)
        confidence, bpm = analyzer.analyze(phases)
        assert confidence > 0.2, f"Expected HR detection, got confidence={confidence}"
        assert 95 < bpm < 105, f"Expected ~100 BPM, got {bpm}"

    def test_short_window_still_works(self):
        """Shorter window (100 frames) should still detect strong HR signal."""
        from ghv4.breathing import HeartRateAnalyzer
        analyzer = HeartRateAnalyzer()
        n_time = 100
        n_pairs = 5
        t = np.arange(n_time) / 20.0
        phases = np.column_stack([np.sin(2 * np.pi * 1.0 * t)] * n_pairs).astype(np.float32)
        confidence, bpm = analyzer.analyze(phases)
        assert isinstance(confidence, float)
        assert isinstance(bpm, float)

    def test_single_pair(self):
        """HeartRateAnalyzer should work with a single subcarrier pair."""
        from ghv4.breathing import HeartRateAnalyzer
        analyzer = HeartRateAnalyzer()
        n_time = 300
        t = np.arange(n_time) / 20.0
        phases = np.sin(2 * np.pi * 1.0 * t).reshape(-1, 1).astype(np.float32)
        confidence, bpm = analyzer.analyze(phases)
        assert confidence > 0.2, f"Single pair should detect HR, got confidence={confidence}"
        assert 55 < bpm < 65, f"Expected ~60 BPM, got {bpm}"

    def test_custom_band_hz(self):
        """Custom band_hz should restrict detection to specified range."""
        from ghv4.breathing import HeartRateAnalyzer
        # Only look in 1.5-2.0 Hz band — 1.0 Hz signal should NOT be detected
        analyzer = HeartRateAnalyzer(band_hz=(1.5, 2.0))
        n_time = 300
        n_pairs = 10
        t = np.arange(n_time) / 20.0
        phases = np.column_stack([np.sin(2 * np.pi * 1.0 * t)] * n_pairs).astype(np.float32)
        confidence, bpm = analyzer.analyze(phases)
        # The 1.0 Hz signal is outside [1.5, 2.0] band, so confidence should be low
        assert confidence < 0.3, f"1.0 Hz outside [1.5,2.0] band should be low: {confidence}"


class TestDualBandFusion:
    def test_max_of_breathing_and_hr(self):
        """Vital confidence should be max(breathing, heartrate)."""
        breathing = 0.4
        heartrate = 0.7
        vital = max(breathing, heartrate)
        assert vital == 0.7

    def test_path_active_above_threshold(self):
        """Path is active if vital_confidence > threshold."""
        from ghv4.config import HEARTRATE_CONFIDENCE_THRESHOLD
        vital = 0.25
        assert vital > HEARTRATE_CONFIDENCE_THRESHOLD


import struct


class TestFullPipelineSynthetic:
    @staticmethod
    def _make_csi_bytes_with_vital_signs(n_sub, t_val, has_breathing, has_hr):
        """Generate CSI bytes with breathing/HR modulation in BOTH amplitude and phase."""
        base_amp = 1000
        breath_mod = 800 * np.sin(2 * np.pi * 0.25 * t_val) if has_breathing else 0
        hr_mod = 100 * np.sin(2 * np.pi * 1.0 * t_val) if has_hr else 0
        amp = int(base_amp + breath_mod + hr_mod)
        result = bytearray()
        for sc in range(n_sub):
            phase = 0.0
            if has_breathing:
                phase += 0.5 * np.sin(2 * np.pi * 0.25 * t_val) * (sc / n_sub)
            if has_hr:
                phase += 0.1 * np.sin(2 * np.pi * 1.0 * t_val) * (sc / n_sub)
            i_val = int(amp * np.cos(phase))
            q_val = int(amp * np.sin(phase))
            result.extend(struct.pack('<hh', i_val, q_val))
        return bytes(result)

    def test_dual_band_detection(self):
        """Full pipeline: breathing+HR on one path → that path detected."""
        from ghv4.breathing import BreathingDetector
        from ghv4.config import BREATHING_WINDOW_N, BREATHING_SNAP_HZ, BREATHING_PATH_MAP

        det = BreathingDetector()
        n_time = BREATHING_WINDOW_N
        t = np.arange(n_time) / BREATHING_SNAP_HZ
        hot_path = (1, 3)

        for step in range(n_time):
            for key in BREATHING_PATH_MAP:
                if key == hot_path:
                    csi = self._make_csi_bytes_with_vital_signs(128, t[step], True, True)
                else:
                    csi = self._make_csi_bytes_with_vital_signs(128, t[step], False, False)
                det.feed_frame('csi_snap', {
                    'reporter_id': key[0], 'peer_id': key[1], 'csi': csi
                })

        scores = det.get_grid_scores()
        # Hot path (1,3) covers r2c0, r1c1, r0c2
        assert scores["r1c1"] is not None and scores["r1c1"] > 10.0, \
            f"Center cell should detect vital signs, got {scores['r1c1']}"

    def test_frame_stats_tracked(self):
        """BreathingDetector tracks accepted/rejected frame counts."""
        from ghv4.breathing import BreathingDetector
        det = BreathingDetector()
        # Feed a frame with coherent phase (will be accepted)
        csi = b''.join(struct.pack('<hh', 1000, 0) for _ in range(128))
        det.feed_frame('csi_snap', {'reporter_id': 1, 'peer_id': 2, 'csi': csi})
        stats = det.get_frame_stats()
        assert stats["accepted"] + stats["rejected"] == 1
